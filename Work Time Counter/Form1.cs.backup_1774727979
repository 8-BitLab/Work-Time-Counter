        /// <summary>
        /// Build the calendar panel and add it to the online-users sidebar.
        /// The calendar sits below the user list, above the version panel.
        /// </summary>
        /// <summary>Build the calendar/date organizer in the team status sidebar.
        /// Shows mini calendar with entry markers, supports clicking dates to open day organizer.
        /// </summary>
        private void BuildCalendarPanel()
        {
            _orgSettings = OrganizerStorage.LoadSettings();
            _calendarVisible = _orgSettings.ShowCalendar;

            // ── IMPORTANT: panelOnlineUsers has AutoScroll=true, which breaks
            // Dock=Bottom for child controls. Instead, we position the calendar
            // with explicit coordinates + anchor to Bottom/Left/Right so it
            // always sits in the empty space below the user list. ──
            int calendarHeight = _orgSettings.CompactView ? 170 : 210;

            _calendarPanel = new CalendarPanel
            {
                Dock = DockStyle.None,
                Size = new Size(panelOnlineUsers.ClientSize.Width - 8, calendarHeight),
                Anchor = AnchorStyles.Left | AnchorStyles.Right | AnchorStyles.Bottom,
                Visible = _orgSettings.ShowCalendar
            };
            // Position just above the version panel (which is ~50px from bottom)
            _calendarPanel.Location = new Point(2, panelOnlineUsers.ClientSize.Height - calendarHeight - 52);

            _calendarPanel.ApplyTheme(isDarkMode, _customTheme);
            _calendarPanel.SetFirstDayOfWeek(_orgSettings.FirstDayOfWeek);
            _calendarPanel.SetShowWeekNumbers(_orgSettings.ShowWeekNumbers);
            _calendarPanel.RefreshEntryMarkers();

            // Wire events: click → open day popup, double-click → quick-add
            _calendarPanel.DateClicked += CalendarPanel_DateClicked;
            _calendarPanel.DateDoubleClicked += CalendarPanel_DateDoubleClicked;

            panelOnlineUsers.Controls.Add(_calendarPanel);
