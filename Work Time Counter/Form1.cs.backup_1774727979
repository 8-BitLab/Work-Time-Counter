        // ============================================================
        // START BUTTON — WORKING STATE ANIMATION
        // When timer is running: button shows "⏳ Working..." with
        // animated dots and a pulsing amber color. Disabled for clicks.
        // When timer stops: button restores to green "▶  START".
        // ============================================================
        private void SetStartButtonWorking(bool isWorking)
        {
            // Toggle START button between enabled (green) and working (amber) states
            DebugLogger.Log($"[Form1] SetStartButtonWorking: Setting working state to {isWorking}");
            if (isWorking)
            {
                // Save original state
                _startBtnOriginalColor = buttonStart.BackColor;
                _startBtnOriginalText = buttonStart.Text;

                // Set working appearance — amber/orange with animated text
                buttonStart.Enabled = false;
                buttonStart.Text = "⏳ Working";
                buttonStart.BackColor = Color.FromArgb(245, 158, 11);  // Amber
                buttonStart.ForeColor = Color.White;
                buttonStart.Cursor = Cursors.Default;
                _startBtnAnimDots = 0;

                // Start animation timer — cycles dots every 500ms
                if (_startBtnAnimTimer == null)
                {
                    _startBtnAnimTimer = new Timer();
                    _startBtnAnimTimer.Interval = 500;
                    _startBtnAnimTimer.Tick += StartBtnAnimTimer_Tick;
                }
                _startBtnAnimTimer.Start();
            }
            else
            {
                // Stop animation
                _startBtnAnimTimer?.Stop();

                // Restore original appearance
                buttonStart.Enabled = true;
                buttonStart.Text = _startBtnOriginalText ?? "▶  START";
                buttonStart.BackColor = _startBtnOriginalColor != Color.Empty
                    ? _startBtnOriginalColor
                    : Color.FromArgb(34, 197, 94);
                buttonStart.ForeColor = Color.White;
                buttonStart.Cursor = Cursors.Hand;
            }
        }

